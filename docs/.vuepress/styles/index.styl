// 站点自定义样式（可选）
// 主题变量见：https://github.com/xugaoyi/vuepress-theme-vdoing/blob/master/theme-vdoing/styles/palette.styl

.theme-vdoing-content
  font-size 16px

// Make existing breadcrumbs easier to spot as parent navigation
.articleInfo .breadcrumbs
  font-size 0.92rem
  a
    text-decoration none
    &:hover
      text-decoration underline

.allen-parent-back
  display flex
  align-items center
  gap 0.75rem
  flex-wrap wrap
  max-width 960px
  margin 0.85rem auto 0
  padding 0 1.5rem
  a
    display inline-flex
    align-items center
    gap 0.35rem
    font-size 0.9rem
    font-weight 600
    text-decoration none
    color var(--textColor, inherit)
    opacity 0.85
    &:hover
      opacity 1
      text-decoration underline
  .allen-parent-sep
    opacity 0.35

@media (max-width: 719px)
  .allen-parent-back
    padding 0 1rem
    margin-top 0.65rem
